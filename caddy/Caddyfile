{
	# SSL
	email {$ADMIN_EMAIL}

	# TESTING and DEVELOPMENT
	# Uncomment this to enable staging certificates to avoid rate limits
	# If this is uncommented, see header section below!
	# https://letsencrypt.org/docs/rate-limits/
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory

	# Uncomment to see headers set by upstream
	# debug

	# Trust home lan proxy. CIDRs are space-separated; configure via
	# CADDY_TRUSTED_PROXIES in .env.
	servers {
		trusted_proxies static {$CADDY_TRUSTED_PROXIES}
		trusted_proxies_strict
	}
}

# ----------------------------------------------------------------------------
# Trusted-proxy / real-client-IP debug snippets.
# Selected at parse time via {$CADDY_DEBUG_SNIPPET} in the site block below.
# Default (debug_headers_off) is a no-op. Set CADDY_DEBUG_SNIPPET=debug_headers_on
# in .env and re-run ./caddy_update.sh to enable JSON access logs and the
# /caddy-debug-headers endpoint.
# ----------------------------------------------------------------------------
(debug_headers_off) {
	# no-op placeholder — header debug logging disabled
}

(debug_headers_on) {
	# Per-site JSON access log to stdout. The default JSON encoder serializes
	# request.headers (incl. X-Forwarded-For/-Proto/-Host, X-Real-IP,
	# Forwarded, Host), request.remote_ip (TCP peer) and request.client_ip
	# (parsed via global trusted_proxies). Visible via `docker compose logs caddy`.
	log {
		output stdout
		format json
	}

	# Plain-text debug endpoint. Curl this to see exactly what Caddy sees
	# for the headers Nextcloud relies on for real-client-IP attribution.
	@debug_headers path /caddy-debug-headers
	handle @debug_headers {
		header Cache-Control "no-store"
		header Content-Type "text/plain; charset=utf-8"
		respond <<HEADERS
remote_ip (peer):  {http.request.remote.host}
client_ip (real):  {client_ip}
host:              {http.request.host}
proto (peer):      {http.request.scheme}
X-Forwarded-For:   {http.request.header.X-Forwarded-For}
X-Forwarded-Proto: {http.request.header.X-Forwarded-Proto}
X-Forwarded-Host:  {http.request.header.X-Forwarded-Host}
X-Real-IP:         {http.request.header.X-Real-IP}
Forwarded:         {http.request.header.Forwarded}
Via:               {http.request.header.Via}
HEADERS 200
	}
}

# ----------------------------------------------------------------------------
# Per-site JSON access log on stdout. Captured by the Docker log driver and
# visible via `docker compose logs caddy`. Selected at parse time via
# {$CADDY_ACCESS_LOG_SNIPPET} in the site block. Default (access_log_off) is
# a no-op. Set CADDY_ACCESS_LOG_SNIPPET=access_log_on in .env and re-run
# ./caddy_update.sh to enable.
# ----------------------------------------------------------------------------
(access_log_off) {
	# no-op placeholder — access logging disabled
}

(access_log_on) {
	log {
		output stdout
		format json
	}
}

{$TLS_DOMAINS} {
	{$CADDY_TLS}

	# Pull in trusted-proxy / real-client-IP debug snippet (see top of file).
	# Snippet name is supplied via env var; defaults to the no-op snippet.
	import {$CADDY_DEBUG_SNIPPET}

	# Pull in per-site access log snippet (see top of file).
	# Snippet name is supplied via env var; defaults to the no-op snippet.
	import {$CADDY_ACCESS_LOG_SNIPPET}

	# Static content
	root * /var/www/html

	# PHP fast cgi
	php_fastcgi app:9000 {
		env front_controller_active true
	}

	file_server

	# Redirects for DAV apps
	redir /.well-known/carddav /remote.php/dav/ 301
	redir /.well-known/caldav /remote.php/dav/ 301

	respond /.well-known/acme-challenge 404
	respond /.well-known/pki-validation 404

	# redir /.well-known/* /index.php/.well-known/webfinger 301
	# redir /.well-known/nodeinfo /index.php/.well-known/nodeinfo 301
	redir /.well-known/* /index.php{uri} 301

	# Headers
	header {
		# If staging acme_ca is enabled, this needs to be commented out!
		# Otherwise, it is not possible to add browser exception
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

		# More security hardening headers
		Referrer-Policy "no-referrer"
		X-Content-Type-Options "nosniff"
		X-Download-Options "noopen"
		X-Frame-Options "SAMEORIGIN"
		X-Permitted-Cross-Domain-Policies "none"
		X-Robots-Tag "noindex, nofollow"
		X-XSS-Protection "1; mode=block"
		# Permissions-Policy "interest-cohort=()"

		# Remove X-Powered-By header, which is an information leak
		-X-Powered-By

		# Replace http with https in any Location header
		Location http:// https://
	}

	# Cache control
	@static {
		file
		path *.css *.js *.svg *.gif
	}

	header @static {
		Cache-Control "max-age=360"
	}

	@fonts {
		path /core/fonts
	}

	header @fonts {
		Cache-Control "max-age=604800"
	}

	# gzip encoding
	encode {
		gzip 4
		minimum_length 256

		match {
			header Content-Type application/atom+xml*
			header Content-Type application/javascript*
			header Content-Type application/json*
			header Content-Type application/ld+json*
			header Content-Type application/manifest+json*
			header Content-Type application/rss+xml*
			header Content-Type application/vnd.geo+json*
			header Content-Type application/vnd.ms-fontobject*
			header Content-Type application/x-font-ttf*
			header Content-Type application/x-web-app-manifest+json*
			header Content-Type application/xhtml+xml*
			header Content-Type application/xml*
			header Content-Type font/opentype*
			header Content-Type image/bmp*
			header Content-Type image/svg+xml*
			header Content-Type image/x-icon*
			header Content-Type application/atom+xmlapplication/javascript*
			# Would this be a good idea?
			header Content-Type text/*
			# header Content-Type text/cache-manifest*
			# header Content-Type text/css*
			# header Content-Type text/plain*
			# header Content-Type text/vcard*
			# header Content-Type text/vnd.rim.location.xloc*
			# header Content-Type text/vtt*
			# header Content-Type text/x-component*
			# header Content-Type text/x-cross-domain-policy*
		}
	}

	# .htaccess / data / config / ... shouldn't be accessible from outside
	@forbidden {
		path /.htaccess
		path /.user.ini
		path /.xml
		path /3rdparty/*
		path /autotest
		path /build/*
		path /config/*
		path /console
		path /console.php
		path /data/*
		path /db_
		path /db_structure
		path /indie
		path /issue
		path /lib/*
		path /occ
		path /README
		path /templates/*
		path /tests/*
	}

	respond @forbidden 404
	# not sure if this is 100% safe, but it looks nicer when you hit a 404
	# rewrite @forbidden '/index.php/error/404'
}
